  <meta name="description" content="Yan Matheus — Engenheiro de Computação & Analista de Infraestrutura baseado em Belém, Pará." />
  <title>Yan Matheus</title>
  <script>(function(){var s=localStorage.getItem('isDarkMode'),mq=window.matchMedia('(prefers-color-scheme:dark)'),d=s!==null?s==='true':mq.matches;document.documentElement.classList.toggle('dark',d)})()</script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={darkMode:'class'}</script>
  <style>
    body{font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif}
    .bg-dot-white{background-image:radial-gradient(rgba(255,255,255,0.2) 1px,transparent 1px);background-size:16px 16px}
    .bg-dot-black{background-image:radial-gradient(rgba(0,0,0,0.2) 1px,transparent 1px);background-size:16px 16px}
    .tooltip{opacity:0;transition:opacity 0.15s;pointer-events:none}
    .group:hover .tooltip{opacity:1}
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{transition-duration:0ms!important;animation:none!important}}
  </style>
</head>
<body class="bg-white dark:bg-black antialiased">

<div class="w-full dark:bg-black bg-white min-h-screen relative">
